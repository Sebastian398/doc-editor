generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Document {
  id        String   @id @default(cuid())
  name      String
  fileUrl   String
  createdAt DateTime @default(now())
  fields    Field[]
  rooms  Room[]
}

model Field {
  id         String @id @default(cuid())
  type       String
  x          Float
  y          Float
  width      Float
  height     Float
  xRatio     Float?
  yRatio     Float?
  widthRatio Float?
  heightRatio Float?
  page Int @default(1)
  pageWidth Float?
  pageHeight Float?
  documentId String
  Document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  responses Response[]
}

model Room {
  id         String   @id @default(cuid())
  documentId String
  link       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  responses  Response[]
  flowItems FlowRoomItem[]
}
model Response {
  id       String @id @default(cuid())
  value    String @db.LongText
  fieldId  String
  field   Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  roomId   String
  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}
model Flow {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  items FlowRoomItem[]
  rooms FlowRoom[]
}
model FlowRoomItem {
  id     String @id @default(cuid())
  flowId String
  roomId String
  flow   Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  @@unique([flowId, roomId])
}
model FlowRoom {
  id        String @id @default(cuid())
  flowId    String
  link      String @unique
  flow      Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}